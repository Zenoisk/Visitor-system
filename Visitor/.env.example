APP_NAME="AIROD Visitor Management System"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://your-company-domain

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=airod_visitor_management
DB_USERNAME=your_database_user
DB_PASSWORD=your_strong_password

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Demo User Seeding configuration (For local / staging only; Set to false in production)
ENABLE_DEMO_USERS=false
DEMO_ADMIN_EMAIL=admin@airod.test
DEMO_ADMIN_USERNAME=admin
DEMO_ADMIN_PASSWORD=password
DEMO_SECURITY_EMAIL=security@airod.test
DEMO_SECURITY_USERNAME=security
DEMO_SECURITY_PASSWORD=password

VITE_APP_NAME="${APP_NAME}"
